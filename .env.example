# ─────────────────────────────────────────────────────────────
# AdReel environment. Copy to `.env` and fill in.
# Everything works locally with just AUTH_SECRET + DATABASE_URL.
# ─────────────────────────────────────────────────────────────

# App
NODE_ENV=development
APP_URL=http://localhost:3000

# Auth — REQUIRED. Generate one with: openssl rand -base64 32
AUTH_SECRET=

# Database — SQLite by default. Swap for a Postgres URL in production.
DATABASE_URL="file:./dev.db"

# ── AI providers (all optional; sensible free/local defaults are used) ──
# Script generation via local Ollama (https://ollama.com). If unreachable,
# a deterministic template writer is used instead — the app never hard-fails.
SCRIPT_PROVIDER=ollama            # ollama | template
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Text-to-speech. `say` uses the built-in macOS voice (zero-dependency).
TTS_PROVIDER=say                  # say | piper | kokoro
PIPER_BIN=                        # path to piper binary if TTS_PROVIDER=piper
PIPER_VOICE=                      # path to a piper .onnx voice model

# Caption timing. `estimate` distributes words across the measured audio.
CAPTIONS_PROVIDER=estimate        # estimate | whisper
WHISPER_BIN=                      # path to whisper.cpp binary if using whisper

# Avatar motion. `kenburns` = still image with subtle zoom/pan (no GPU).
# `lipsync` requires a GPU + a configured SadTalker/Wav2Lip endpoint.
AVATAR_PROVIDER=kenburns          # kenburns | lipsync
LIPSYNC_ENDPOINT=

# ── Billing (optional) — without these, a mock provider runs locally ──
BILLING_PROVIDER=mock             # mock | stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Monthly price ids
STRIPE_PRICE_STARTER=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_SCALE=
# Annual price ids (10× monthly = 2 months free). Falls back to monthly if unset.
STRIPE_PRICE_STARTER_YEARLY=
STRIPE_PRICE_GROWTH_YEARLY=
STRIPE_PRICE_SCALE_YEARLY=
